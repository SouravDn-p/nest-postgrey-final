generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email String  @unique
  role      Role     @default(USER)
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 